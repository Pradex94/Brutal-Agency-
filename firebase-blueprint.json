{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A potential client who submitted the contact form.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the lead."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the lead."
        },
        "website": {
          "type": "string",
          "description": "The website URL of the lead's brand."
        },
        "Revenue": {
          "type": "string",
          "description": "The monthly revenue range of the lead."
        },
        "Bottleneck": {
          "type": "string",
          "description": "The biggest bottleneck identified by the lead."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the lead was submitted."
        },
        "status": {
          "type": "string",
          "enum": ["new", "contacted", "closed"],
          "description": "The current status of the lead."
        },
        "userId": {
          "type": "string",
          "description": "The UID of the user this lead belongs to."
        }
      },
      "required": ["name", "email", "createdAt"]
    },
    "Activity": {
      "title": "Activity",
      "description": "A log of user actions or system events.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "createdAt"]
    },
    "Automation": {
      "title": "Automation",
      "description": "Status of various automations for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "whatsapp": { "type": "string", "enum": ["active", "inactive"] },
        "email": { "type": "string", "enum": ["active", "inactive"] },
        "chatbot": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["userId"]
    },
    "LeadRequest": {
      "title": "LeadRequest",
      "description": "A request for lead generation.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "businessType": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "running", "completed", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "businessType", "location", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user of the platform.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the user."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The role of the user."
        },
        "isPaid": {
          "type": "boolean",
          "description": "Whether the user has a paid subscription."
        }
      },
      "required": ["email", "role"]
    },
    "ClientLead": {
      "title": "ClientLead",
      "description": "A lead generated from external sources like Google Maps.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "website": { "type": "string" },
        "rating": { "type": "number" },
        "status": { "type": "string", "enum": ["new", "contacted", "closed"] },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["name", "createdAt"]
    },
    "SeoReport": {
      "title": "SeoReport",
      "description": "A main SEO report document.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "website": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "website", "createdAt"]
    },
    "SeoAudit": {
      "title": "SeoAudit",
      "description": "Audit subcollection data.",
      "type": "object",
      "properties": {
        "overall_seo_score": { "type": "number" },
        "seo_grade": { "type": "string" },
        "lost_revenue": { "type": "number" },
        "weaknesses": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "SeoOnPage": {
      "title": "SeoOnPage",
      "description": "On-page SEO subcollection data.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "meta_description": { "type": "string" },
        "h1_count": { "type": "number" },
        "h2_count": { "type": "number" },
        "images_total": { "type": "number" },
        "images_missing_alt": { "type": "number" },
        "ssl": { "type": "boolean" },
        "structured_data": { "type": "boolean" }
      }
    },
    "SeoPageSpeed": {
      "title": "SeoPageSpeed",
      "description": "PageSpeed subcollection data.",
      "type": "object",
      "properties": {
        "mobile_performance": { "type": "number" },
        "mobile_seo": { "type": "number" },
        "desktop_performance": { "type": "number" },
        "desktop_seo": { "type": "number" }
      }
    },
    "SeoIndexation": {
      "title": "SeoIndexation",
      "description": "Indexation subcollection data.",
      "type": "object",
      "properties": {
        "total_indexed_pages": { "type": "number" }
      }
    },
    "SeoRecommendation": {
      "title": "SeoRecommendation",
      "description": "Recommendation subcollection data.",
      "type": "object",
      "properties": {
        "priority": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"] },
        "action": { "type": "string" },
        "impact": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of leads from the contact form."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of users and their roles."
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Log of user activities."
    },
    "/automations/{automationId}": {
      "schema": "Automation",
      "description": "Status of user automations."
    },
    "/lead_requests/{requestId}": {
      "schema": "LeadRequest",
      "description": "Collection of lead generation requests."
    },
    "/client_leads/{leadId}": {
      "schema": "ClientLead",
      "description": "Collection of leads generated by automations."
    },
    "/seo_reports/{reportId}": {
      "schema": "SeoReport",
      "description": "Main SEO reports collection."
    },
    "/seo_reports/{reportId}/audit/data": {
      "schema": "SeoAudit",
      "description": "Audit data for the report."
    },
    "/seo_reports/{reportId}/on_page/data": {
      "schema": "SeoOnPage",
      "description": "On-page data for the report."
    },
    "/seo_reports/{reportId}/pagespeed/data": {
      "schema": "SeoPageSpeed",
      "description": "PageSpeed data for the report."
    },
    "/seo_reports/{reportId}/indexation/data": {
      "schema": "SeoIndexation",
      "description": "Indexation data for the report."
    },
    "/seo_reports/{reportId}/recommendations/{recId}": {
      "schema": "SeoRecommendation",
      "description": "Recommendations for the report."
    }
  }
}
